#!/bin/bash
# MARK: - Pre-push Hook for MeetingAssistant
# Ensures tests pass before pushing. Set SKIP_TESTS=1 to bypass.

set -e

if [ "${SKIP_TESTS}" = "1" ]; then
    echo "⚠️  SKIP_TESTS=1 set. Skipping tests."
    exit 0
fi

echo "🧪 Running tests before push..."
DEFAULT_BRANCH="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')"
if [ -z "${DEFAULT_BRANCH}" ]; then
    DEFAULT_BRANCH="main"
fi

if [ "${PUSH_CHECK_VERBOSE:-0}" = "1" ]; then
    make scope-check ARGS="--base ${DEFAULT_BRANCH}"
else
    make scope-check-agent ARGS="--base ${DEFAULT_BRANCH}"
fi
