#!/bin/bash
# Pre-push hook: acknowledges the push range without running build or test
# validation. Technical validation (lint / build / tests via validate-agent)
# is owned by end-of-task development, not by this hook.

set -u
set -o pipefail

REMOTE_ARGUMENT="${1:-origin}"
REMOTE_NAME="${REMOTE_ARGUMENT}"
DIRECT_URL=0
if git remote get-url "${REMOTE_ARGUMENT}" >/dev/null 2>&1; then
    DIRECT_URL=0
else
    case "${REMOTE_ARGUMENT}" in
        *://*|*:*|/*|./*|../*|*/*|*.git)
            DIRECT_URL=1
            REMOTE_NAME=""
            ;;
        *)
            # A configured remote name wins above; otherwise an existing
            # path is treated as a direct Git transport.
            if [ -e "${REMOTE_ARGUMENT}" ]; then
                DIRECT_URL=1
                REMOTE_NAME=""
            fi
            ;;
    esac
fi

current_branch_ref="$(git symbolic-ref -q HEAD 2>/dev/null || true)"

acknowledge_push_range() {
    local local_ref="$1"
    local local_sha="$2"
    local remote_ref="$3"
    local remote_sha="$4"

    # Deletions and tag-only pushes do not change the source tree being checked.
    if [ "${local_sha}" = "0000000000000000000000000000000000000000" ]; then
        echo "ℹ️  Skipping deleted ref ${local_ref}."
        return 0
    fi
    case "${local_ref}" in
        refs/tags/*)
            echo "ℹ️  Skipping tag push ${local_ref}."
            return 0
            ;;
    esac

    if [ -z "${current_branch_ref}" ]; then
        echo "Error: pre-push requires a checked-out local branch; received ${local_ref}." >&2
        return 1
    fi
    if [ "${local_ref}" != "${current_branch_ref}" ]; then
        echo "Error: refusing to push ${local_ref} while ${current_branch_ref} is checked out." >&2
        echo "       Push the checked-out branch or push this ref explicitly outside the hook." >&2
        return 1
    fi
    if ! git rev-parse --verify "${local_sha}^{commit}" >/dev/null 2>&1; then
        echo "Error: local push head ${local_sha} is not a commit." >&2
        return 1
    fi

    echo "ℹ️  Pre-push: ${local_ref} → ${remote_ref}"
    echo "   head: ${local_sha}"
    if [ "${remote_sha}" = "0000000000000000000000000000000000000000" ]; then
        echo "   remote: new ref"
    else
        echo "   remote tip: ${remote_sha}"
    fi
    if [ "${DIRECT_URL}" -eq 1 ]; then
        echo "   transport: direct URL"
    else
        echo "   remote: ${REMOTE_NAME}"
    fi
    echo "   note: build/test gates are owned by end-of-task development, not by this hook."
    return 0
}

branch_push_seen=0
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha _; do
    [ -n "${local_ref}" ] || continue
    case "${local_ref}" in
        refs/tags/*) acknowledge_push_range "${local_ref}" "${local_sha}" "${remote_ref}" "${remote_sha}" || exit $? ;;
        refs/heads/*)
            branch_push_seen=$((branch_push_seen + 1))
            acknowledge_push_range "${local_ref}" "${local_sha}" "${remote_ref}" "${remote_sha}" || exit $?
            ;;
        *)
            if [ "${local_sha}" = "0000000000000000000000000000000000000000" ]; then
                echo "ℹ️  Skipping deleted ref ${local_ref}."
            else
                echo "Error: refusing to push unsupported local ref ${local_ref}." >&2
                exit 1
            fi
            ;;
    esac
done

if [ "${branch_push_seen}" -eq 0 ]; then
    echo "ℹ️  No branch commit requires pre-push acknowledgment."
fi
