#!/bin/bash
# MARK: - Pre-commit Hook for MeetingAssistant (Optimized)
# Fast checks on STAGED files only - blocking lint/format

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
DAILY_BUMP_SCRIPT="${PROJECT_ROOT}/scripts/hooks/first-commit-version-bump.sh"

cd "${PROJECT_ROOT}"

# Auto-bump version on the first commit of the day.
if [ -x "${DAILY_BUMP_SCRIPT}" ]; then
    "${DAILY_BUMP_SCRIPT}"
fi

echo "🔍 Running pre-commit checks (staged files only)..."
echo ""

# Get staged Swift files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo "ℹ️  No Swift files staged for commit."
    echo ""
    echo "🎉 Pre-commit checks passed!"
    exit 0
fi

# Lint/format checks run by default. Set SKIP_LINT=1 to bypass.
if [ "${SKIP_LINT}" = "1" ]; then
    echo "ℹ️  Lint/format checks skipped via SKIP_LINT=1."
    echo ""
    echo "🎉 Pre-commit checks passed!"
    exit 0
fi

# Required tools are part of the staged Swift gate.
if ! command -v swiftformat &> /dev/null; then
    echo "❌ SwiftFormat is required for staged Swift checks. Install with: brew install swiftformat"
    exit 1
fi

if ! command -v swiftlint &> /dev/null; then
    echo "❌ SwiftLint is required for staged Swift checks. Install with: brew install swiftlint"
    exit 1
fi

# Count staged files
FILE_COUNT=$(echo "$STAGED_FILES" | wc -l | xargs)
echo "   Found $FILE_COUNT staged Swift file(s)"
echo ""

# 1. SwiftFormat check (only staged files)
echo "1️⃣  Checking code formatting..."
FORMAT_FAILED=0
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        if command -v swiftformat &> /dev/null; then
            if ! swiftformat --lint --config .swiftformat "$file" 2>/dev/null; then
                FORMAT_FAILED=1
            fi
        fi
    fi
done

if [ $FORMAT_FAILED -eq 1 ]; then
    echo "❌ Code formatting issues found. Run 'make lint-fix' to fix before committing."
    exit 1
else
    echo "   ✅ Formatting OK"
fi

# 2. SwiftLint check (only staged files)
echo "2️⃣  Running SwiftLint..."
LINT_FAILED=0
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        if command -v swiftlint &> /dev/null; then
            if ! swiftlint lint --config .swiftlint.yml --quiet "$file" 2>/dev/null; then
                LINT_FAILED=1
            fi
        fi
    fi
done

if [ $LINT_FAILED -eq 1 ]; then
    echo "❌ SwiftLint violations found. Run 'make lint-fix' or 'make lint' to remediate."
    exit 1
else
    echo "   ✅ SwiftLint OK"
fi

echo ""
echo "🎉 All pre-commit checks passed!"
echo ""
echo "💡 Tip: Scoped validation runs on 'git push' (pre-push hook)"
echo ""
